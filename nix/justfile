# Quick Host Reference
# ====================

# Show all available hosts
hosts:
    @echo "Available configurations:"
    @echo ""
    @nix eval "path:$FLAKE_DIR/nix"#nixosConfigurations --apply 'builtins.attrNames' --json 2>/dev/null | jq -r '.[]' | sed 's/^/  nixos: /' || true
    @nix eval "path:$FLAKE_DIR/nix"#darwinConfigurations --apply 'builtins.attrNames' --json 2>/dev/null | jq -r '.[]' | sed 's/^/  darwin: /' || true
    @nix eval "path:$FLAKE_DIR/nix"#homeConfigurations --apply 'builtins.attrNames' --json 2>/dev/null | jq -r '.[]' | sed 's/^/  home:   /' || true
