# Nix Configuration - Justfile
# Inspired by wimpysworld/nix-config
# 
# Automatically detects current hostname and builds the appropriate configuration

# Git repo root (nix flake is in the nix/ subdirectory)
export FLAKE_DIR := env_var("HOME") / "dotfiles"

# Get current system info
host := `hostname -s`
user := `whoami`

# Default recipe shows help
default:
    @just --list --unsorted

# Build and switch OS configuration (auto-detects platform)
switch:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname)" = "Linux" ] && command -v nixos-rebuild &>/dev/null; then
        just switch-host
        just switch-home
    elif [ "$(uname)" = "Darwin" ]; then
        just switch-host
        just switch-home
    else
        # Non-NixOS Linux - only switch home-manager
        just switch-home
    fi

# Build OS and Home configurations without switching
build:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname)" = "Linux" ] && command -v nixos-rebuild &>/dev/null; then
        just build-host
        just build-home
    elif [ "$(uname)" = "Darwin" ]; then
        just build-host
        just build-home
    else
        # Non-NixOS Linux - only build home-manager
        just build-home
    fi

# Check flake for errors
check:
    @nix flake check --show-trace "path:$FLAKE_DIR/nix" 2>&1 || true

# Evaluate configurations without building
eval:
    @echo "Evaluating flake configurations..."
    @nix flake show "path:$FLAKE_DIR/nix" 2>&1 | head -50

# Update flake inputs
update:
    @echo "Updating flake.lock..."
    @nix flake update --flake "path:$FLAKE_DIR/nix"

# Clean up old generations
gc:
    @echo "Running garbage collection..."
    @nix-collect-garbage -d

# Optimize nix store
optimise:
    @nix-store --optimise

# Format all nix files
fmt:
    @find . -name "*.nix" -exec nixpkgs-fmt {} \;

# OS Configuration Commands
# =========================

# Build OS configuration
build-host hostname=host:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Building {{ hostname }}..."
    if [ "$(uname)" = "Linux" ]; then
        nixos-rebuild build --flake "path:$FLAKE_DIR/nix"#{{hostname}}
    elif [ "$(uname)" = "Darwin" ]; then
        darwin-rebuild build --flake "path:$FLAKE_DIR/nix"#{{hostname}}
    else
        echo "Unsupported OS: $(uname)"
        exit 1
    fi

# Switch OS configuration  
switch-host hostname=host:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Switching {{ hostname }}..."
    if [ "$(uname)" = "Linux" ]; then
        sudo nixos-rebuild switch --flake "path:$FLAKE_DIR/nix"#{{hostname}}
    elif [ "$(uname)" = "Darwin" ]; then
        darwin-rebuild switch --flake "path:$FLAKE_DIR/nix"#{{hostname}}
    else
        echo "Unsupported OS: $(uname)"
        exit 1
    fi

# Home Manager Configuration Commands
# ===================================

# Build Home configuration
build-home hostname=host:
    @echo "Building home configuration for {{ hostname }}..."
    @home-manager build --flake "path:$FLAKE_DIR/nix"#{{hostname}}

# Switch Home configuration
switch-home hostname=host:
    @echo "Switching home configuration for {{ hostname }}..."
    @home-manager switch --flake "path:$FLAKE_DIR/nix"#{{hostname}}

